{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "OrderDB": "Server=localhost,1433;Database=OrderDB;User Id=sa;Password=Your_strong_Password123;TrustServerCertificate=True;Encrypt=False"
  },
  "Services": {
    "Inventory": "http://localhost:8081",
    "Notification": "http://localhost:8082"
  },
  "ServiceBus": {
    "Enabled": false,
    "ConnectionString": "",
    "TopicName": "orders"
  },
  "Jwt": {
    "Issuer": "MiniCommerce",
    "Audience": "MiniCommerce",
    "SigningKey": "MiniCommerce_Dev_Signing_Key_Change_In_Production_32chars",
    "ExpirationMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "KeyVault": {
    "Enabled": false,
    "VaultUri": ""
  },
  "Observability": {
    "EnableTracing": false,
    "ApplicationInsightsConnectionString": "",
    "OtlpEndpoint": ""
  },
  "Database": {
    "AutoMigrate": true
  },
  "AllowedHosts": "*"
}
