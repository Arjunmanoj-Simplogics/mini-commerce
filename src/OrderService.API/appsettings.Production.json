{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  },
  "ConnectionStrings": {
    "OrderDB": ""
  },
  "Services": {
    "Inventory": "",
    "Notification": "",
    "HttpClientTimeoutSeconds": 30
  },
  "Jwt": {
    "Issuer": "MiniCommerce",
    "Audience": "MiniCommerce",
    "SigningKey": "",
    "ExpirationMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AzureAuth": {
    "PreferManagedIdentity": true,
    "ManagedIdentityClientId": ""
  },
  "KeyVault": {
    "Enabled": false,
    "VaultUri": "",
    "ReloadIntervalMinutes": 30
  },
  "ServiceBus": {
    "Enabled": true,
    "ConnectionString": "",
    "FullyQualifiedNamespace": "",
    "TopicName": "orders"
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "BlobStorage": {
    "Enabled": false
  },
  "Database": {
    "AutoMigrate": true,
    "CommandTimeoutSeconds": 30,
    "MaxRetryCount": 5,
    "MaxRetryDelaySeconds": 30,
    "UseManagedIdentity": true
  },
  "Hosting": {
    "ShutdownTimeoutSeconds": 30,
    "UseHttpsRedirection": false,
    "MaxRequestBodySizeBytes": 10485760,
    "KeepAliveTimeoutSeconds": 130,
    "RequestHeadersTimeoutSeconds": 30
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "OrderService",
    "OtlpEndpoint": "",
    "OtlpProtocol": "Grpc",
    "ExcludeHealthChecks": true,
    "CaptureSqlText": false,
    "Exporters": {
      "Console": false,
      "Otlp": false,
      "AzureMonitor": true
    }
  }
}
